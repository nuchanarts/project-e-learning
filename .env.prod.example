# Copy to .env.prod and fill in real values. NEVER commit .env.prod.
#   cp .env.prod.example .env.prod

# ---------- Image / proxy ----------
# Registry tag to pull/run. "latest" or a git sha / semver.
VERSION=latest

# Public hostname Caddy serves.
#   - HTTPS: set your real domain (e.g. elearning.example.com). Caddy auto-issues
#     a Let's Encrypt cert. DNS A record must point at this server FIRST.
#   - Plain HTTP (dev/staging, no TLS): use :80
DOMAIN=elearning.example.com

# Host ports for Caddy. Change only if 80/443 are already in use.
HTTP_PORT=80
HTTPS_PORT=443

# Frontend API base (baked in at build). Leave as /api for the Caddy-fronted stack.
VITE_API_URL=/api

# ---------- Backend ----------
# Backend -> MySQL. Host must be the compose service name `mysql`.
DATABASE_URL=mysql://bms_user:CHANGE_ME_STRONG@mysql:3306/bms_elearning?charset=utf8mb4

# Public base URL the backend uses in emails/links (OTP, etc.). Usually https://<DOMAIN>.
FRONTEND_URL=https://elearning.example.com

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_32_BYTES_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email OTP. Keep OTP_ENABLED=false to skip email entirely (SMTP_* can stay blank).
# Set to true only after SMTP below is filled in and verified.
OTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional — Google Sheets KPI export (admin/analytics). Leave blank to disable.
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_ID=

# ---------- MySQL (only used the FIRST time the volume is created) ----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_DATABASE=bms_elearning
MYSQL_USER=bms_user
MYSQL_PASSWORD=CHANGE_ME_STRONG

# Optional — expose MySQL to the host for external admin tools (Navicat, DBeaver).
#   - unset/blank → 127.0.0.1 (reachable only from the server itself)
#   - LAN IP      → e.g. 10.0.0.5 (admins on the same LAN/VPN can connect)
#   - 0.0.0.0     → every interface (DANGEROUS on public servers)
# MYSQL_HOST_BIND=

TZ=Asia/Bangkok
