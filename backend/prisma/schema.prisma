generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum CertTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model User {
  id           String        @id @default(uuid()) @db.VarChar(36)
  email        String        @unique @db.VarChar(191)
  passwordHash String        @db.VarChar(255)
  name         String        @db.VarChar(255)
  role         Role          @default(USER)
  isActive     Boolean       @default(true)
  cid          String?       @unique @db.VarChar(13)
  hospital     String?       @db.VarChar(255)
  position     String?       @db.VarChar(255)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  progress     Progress[]
  certificates Certificate[]
  quizAttempts QuizAttempt[]
}

model Course {
  id                   String          @id @default(uuid()) @db.VarChar(36)
  title                String          @db.VarChar(255)
  description          String          @db.Text
  category             String?         @db.VarChar(100)
  isActive             Boolean         @default(true)
  order                Int             @default(0)
  quizRequired         Boolean         @default(false)
  prerequisiteCourseId String?         @db.VarChar(36)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  videos               Video[]
  certificates         Certificate[]
  documents            CourseDocument[]
  quizQuestions        QuizQuestion[]
  quizAttempts         QuizAttempt[]
  prerequisite         Course?         @relation("CoursePrereq", fields: [prerequisiteCourseId], references: [id])
  dependents           Course[]        @relation("CoursePrereq")
}

model Video {
  id        String     @id @default(uuid()) @db.VarChar(36)
  courseId  String     @db.VarChar(36)
  title     String     @db.VarChar(255)
  url       String     @db.VarChar(512)
  duration  Int
  order     Int
  section   String?    @db.VarChar(100)
  createdAt DateTime   @default(now())
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress  Progress[]

  @@index([courseId, order])
}

model Progress {
  id             String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @db.VarChar(36)
  videoId        String   @db.VarChar(36)
  courseId       String   @db.VarChar(36)
  percent        Float    @default(0)
  completed      Boolean  @default(false)
  watchedSeconds Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, courseId])
}

model Certificate {
  id          String    @id @default(uuid()) @db.VarChar(36)
  userId      String    @db.VarChar(36)
  courseId    String    @db.VarChar(36)
  filePath    String    @db.VarChar(512)
  tier        CertTier?
  quizScore   Float?
  verifyToken String    @unique @default(uuid()) @db.VarChar(36)
  issuedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseDocument {
  id       String @id @default(uuid()) @db.VarChar(36)
  courseId String @db.VarChar(36)
  title    String @db.VarChar(255)
  url      String @db.VarChar(512)
  order    Int    @default(0)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
}

model QuizQuestion {
  id           String @id @default(uuid()) @db.VarChar(36)
  courseId     String @db.VarChar(36)
  text         String @db.Text
  options      String @db.Text
  correctIndex Int
  order        Int    @default(0)
  course       Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
}

model QuizAttempt {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String   @db.VarChar(36)
  courseId    String   @db.VarChar(36)
  score       Float
  passed      Boolean
  answers     String @db.Text
  attemptedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model SiteSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.LongText
  updatedAt DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @db.VarChar(191)
  codeHash  String   @db.VarChar(255)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}
