generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum CertTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model User {
  id           String        @id @default(uuid()) @db.VarChar(36)
  email        String        @unique @db.VarChar(191)
  passwordHash String?       @db.VarChar(255) // null = external auth (e.g. MOPH), no password login
  name         String        @db.VarChar(255)
  role         Role          @default(USER)
  isActive     Boolean       @default(true)
  cid          String?       @unique @db.VarChar(13)
  hospcode     String?       @db.VarChar(10)
  hospital     String?       @db.VarChar(255)
  position     String?       @db.VarChar(255)
  avatarUrl    String?       @db.VarChar(512)
  authProvider String        @default("local") @db.VarChar(20) // 'local' | 'moph'
  providerSub  String?       @unique @db.VarChar(191) // stable subject id from external provider (MOPH)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  progress        Progress[]
  certificates    Certificate[]
  quizAttempts    QuizAttempt[]
  orders          Order[]
  ratings         CourseRating[]
  trainingRecords TrainingRecord[]
}

model Course {
  id                   String          @id @default(uuid()) @db.VarChar(36)
  title                String          @db.VarChar(255)
  description          String          @db.Text
  category             String?         @db.VarChar(100)
  thumbnailUrl         String?         @db.VarChar(512)
  isFeatured           Boolean         @default(false)
  isActive             Boolean         @default(true)
  order                Int             @default(0)
  price                Float?          // null = free
  quizRequired              Boolean         @default(false)
  requireTrainingRecord     Boolean         @default(false)
  prerequisiteCourseId String?         @db.VarChar(36)
  recommendedFor       String?         @db.VarChar(500)  // JSON array of position names
  inBundle             Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  videos               Video[]
  certificates         Certificate[]
  documents            CourseDocument[]
  quizQuestions        QuizQuestion[]
  quizAttempts         QuizAttempt[]
  orders               Order[]
  ratings              CourseRating[]
  bundleCourses        BundleCourse[]
  trainingRecords      TrainingRecord[]
  prerequisite         Course?         @relation("CoursePrereq", fields: [prerequisiteCourseId], references: [id])
  dependents           Course[]        @relation("CoursePrereq")
}

model Video {
  id        String     @id @default(uuid()) @db.VarChar(36)
  courseId  String     @db.VarChar(36)
  title     String     @db.VarChar(255)
  url       String     @db.VarChar(512)
  duration  Int
  order     Int
  section   String?    @db.VarChar(100)
  createdAt DateTime   @default(now())
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress  Progress[]

  @@index([courseId, order])
}

model Progress {
  id             String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @db.VarChar(36)
  videoId        String   @db.VarChar(36)
  courseId       String   @db.VarChar(36)
  percent        Float    @default(0)
  completed      Boolean  @default(false)
  watchedSeconds Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, courseId])
}

model Certificate {
  id          String    @id @default(uuid()) @db.VarChar(36)
  userId      String    @db.VarChar(36)
  courseId    String    @db.VarChar(36)
  filePath    String    @db.VarChar(512)
  tier        CertTier?
  quizScore   Float?
  verifyToken String    @unique @default(uuid()) @db.VarChar(36)
  issuedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseDocument {
  id       String @id @default(uuid()) @db.VarChar(36)
  courseId String @db.VarChar(36)
  title    String @db.VarChar(255)
  url      String @db.VarChar(512)
  order    Int    @default(0)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
}

model QuizQuestion {
  id           String @id @default(uuid()) @db.VarChar(36)
  courseId     String @db.VarChar(36)
  text         String @db.Text
  options      String @db.Text
  correctIndex Int
  order        Int    @default(0)
  course       Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
}

model QuizAttempt {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String   @db.VarChar(36)
  courseId    String   @db.VarChar(36)
  score       Float
  passed      Boolean
  answers     String @db.Text
  attemptedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model SiteSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.LongText
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id            String      @id @default(uuid()) @db.VarChar(36)
  userId        String      @db.VarChar(36)
  courseId      String      @db.VarChar(36)
  amount        Float
  status        OrderStatus @default(PENDING)
  paymentRef    String?     @db.VarChar(255) // gateway transaction ref
  cardLast4     String?     @db.VarChar(4)
  cardBrand     String?     @db.VarChar(20)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, status])
  @@index([userId])
  @@index([courseId])
}

model Hospital {
  hospcode  String  @id @db.VarChar(10)
  name      String  @db.VarChar(255)
  province  String? @db.VarChar(100)
  district  String? @db.VarChar(100)
  isCustom  Boolean @default(false)
  isActive  Boolean @default(true)

  @@index([name])
  @@index([isCustom])
  @@index([isActive])
}

model OtpCode {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @db.VarChar(191)
  codeHash  String   @db.VarChar(255)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Announcement {
  id        String   @id @default(uuid()) @db.VarChar(36)
  title     String   @db.VarChar(255)
  body      String   @db.Text
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CourseRating {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  courseId  String   @db.VarChar(36)
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model CourseBundle {
  id          String         @id @default(uuid()) @db.VarChar(36)
  name        String         @db.VarChar(255)
  description String?        @db.Text
  price       Float
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  courses     BundleCourse[]
}

model BundleCourse {
  bundleId String       @db.VarChar(36)
  courseId String       @db.VarChar(36)
  bundle   CourseBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course   Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([bundleId, courseId])
}

enum TrainingRecordStatus {
  PENDING
  APPROVED
  REJECTED
}

model TrainingRecord {
  id            String               @id @default(uuid()) @db.VarChar(36)
  userId        String               @db.VarChar(36)
  courseId      String?              @db.VarChar(36)

  recordDate    DateTime             @default(now())
  status        TrainingRecordStatus @default(PENDING)
  adminNote     String?              @db.Text

  // Image evidence (base64 or URL)
  imageData     String?              @db.LongText
  imageMimeType String?              @db.VarChar(50)

  // Optional count fields (kept for backward compat)
  triageRed     Int                  @default(0)
  triageYellow  Int                  @default(0)
  triageGreen   Int                  @default(0)
  vitalSigns    Int                  @default(0)
  cc            Int                  @default(0)
  hpi           Int                  @default(0)
  procedures    Int                  @default(0)
  labOrders     Int                  @default(0)
  xrayOrders    Int                  @default(0)
  medications   Int                  @default(0)
  billing       Int                  @default(0)
  otherExpenses Int                  @default(0)

  notes         String?              @db.Text

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([recordDate])
}
