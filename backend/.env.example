# ── MOPH Provider ID login (server-side — keep off the frontend bundle) ──
# Values are issued by the BMS team when the e-learning app is registered.
MOPH_BMS_AUTH_BASE_URL=https://bms-authen-provider.bmscloud.in.th/api/v1/auth  # confirm with BMS
MOPH_BMS_APP_ID=00000000-0000-0000-0000-000000000000          # app_id from BMS
MOPH_BMS_ENCRYPTION_KEY=__32_CHAR_AES_KEY_FROM_BMS__          # 32 chars, encrypts app_id before the proxy call
MOPH_REDIRECT_URI=https://e-learning.bmscloud.in.th          # byte-match: MOPH registration == frontend origin

# (Optional) AES key to decrypt cid_aes from the MOPH token -> auto-fill the 13-digit cid.
# MOPH_BMS_CID_AES_KEY=__ASK_BMS__
